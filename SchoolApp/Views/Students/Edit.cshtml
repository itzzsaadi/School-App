@model SchoolApp.Models.Student

<!DOCTYPE html>
<html>
<head>
    <title>Student Edit Karo</title>
</head>
<body>
    <h1>Student Edit Karo</h1>

    <form asp-action="Edit" method="post">
        <input type="hidden" asp-for="Id" />
        <div>
            <label>Name:</label>
            <input asp-for="Name" />
            <span asp-validation-for="Name" style="color:red"></span>
        </div>
        <div>
            <label>Email:</label>
            <input asp-for="Email" />
            <span asp-validation-for="Email" style="color:red"></span>
        </div>
        <div>
            <label>Age:</label>
            <input asp-for="Age" />
            <span asp-validation-for="Age" style="color:red"></span>
        </div>
        <div>
            <label>Phone:</label>
            <input asp-for="PhoneNumber" />
            <span asp-validation-for="PhoneNumber" style="color:red"></span>
        </div>
        <div>
            <label>Course (Optional):</label>
            <select asp-for="CourseId">
                <option value="">-- Koi Course Nahi --</option>
                @foreach (var course in ViewBag.Courses)
                {
                    <option value="@course.Id">@course.Name</option>
                }
            </select>
        </div>
        <button type="submit">Update Karo</button>
    </form>

    <a href="/Students">Wapas List Pe Jao</a>
</body>

</html>