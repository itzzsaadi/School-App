@model SchoolApp.Models.Course

<!DOCTYPE html>
<html>
<head>
    <title>Naya Course Add Karo</title>
</head>
<body>
    <h1>Naya Course Add Karo</h1>

    <form asp-action="Create" method="post">
        <div>
            <label>Course Name:</label>
            <input asp-for="Name" />
            <span asp-validation-for="Name" style="color:red"></span>
        </div>
        <div>
            <label>Credit Hours:</label>
            <input asp-for="CreditHours" />
            <span asp-validation-for="CreditHours" style="color:red"></span>
        </div>
        <button type="submit">Add Course</button>
    </form>

    <a href="/Course">Wapas List Pe Jao</a>
</body>
</html>