@model SchoolApp.Models.Course



<!DOCTYPE html>
<html>
<head>
    <title>Course Delete Karo</title>
</head>
<body>
    <h1>Kya Sach Mein Delete Karna Hai?</h1>

    <p>Name: @Model.Name</p>
    <p>Credit Hours: @Model.CreditHours</p>

    <p style="color:red;">
        ⚠️ Yeh course delete hone pe saare linked students unlink ho jayein ge!
    </p>

    <form asp-action="Delete" method="post">
        <input type="hidden" asp-for="Id" />
        <input type="hidden" name="X-HTTP-Method-Override" value="DELETE" />
        <button type="submit">Haan, Delete Karo!</button>
        <a href="/Course">Nahi, Wapas Jao</a>
    </form>
</body>
</html>